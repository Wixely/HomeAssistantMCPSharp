{
  "HomeAssistant": {
    "BaseUrl": "http://homeassistant.local:8123/",
    "AccessToken": "",
    "UserAgent": "HomeAssistantMCPSharp",
    "ReadOnly": true,
    "RequestTimeoutSeconds": 30,
    "IgnoreCertificateErrors": false,
    "AllowedEntities": [],
    "BlockedEntities": [],
    "AllowedDomains": [],
    "BlockedDomains": [],
    "MaxStatesReturned": 500,
    "MaxHistoryEntries": 1000,
    "DefaultHistoryHours": 24,
    "DefaultLogbookHours": 24,
    "AttributeValueTruncate": 512,
    "EnableStates": true,
    "EnableServices": true,
    "EnableHistory": true,
    "EnableLogbook": true,
    "EnableTemplate": true,
    "EnableConversation": true,
    "EnableCalendar": true,
    "EnableDiagnostics": true,
    "EnableEvents": true,
    "EnableRegistry": true,
    "EnableShortcuts": true,
    "EnableNotifications": true,
    "EnableEnergy": true,
    "LowBatteryThresholdPct": 20,
    "EnableCameraSnapshot": false,
    "WaitForStatePollSeconds": 1,
    "WaitForStateMaxSeconds": 60,
    "ConversationLanguage": "en"
  },
  "Server": {
    "Host": "localhost",
    "Port": 5703,
    "Path": "/mcp",
    "WindowsServiceName": "HomeAssistantMCPSharp"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/hamcp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
